# Скопируй этот файл в .env.prod и заполни значения
# cp .env.prod.example .env.prod

# PostgreSQL – придумай сложный пароль
POSTGRES_PASSWORD=замени_на_сложный_пароль_123

# JWT – минимум 32 случайных символа
# Сгенерировать: openssl rand -hex 32
JWT_SECRET=замени_на_случайную_строку_минимум_32_символа
REFRESH_TOKEN_SECRET=замени_на_другую_случайную_строку_32_символа

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=замени_на_сложный_пароль_minio

# Секрет для выдачи прав администратора
ADMIN_SECRET=замени_на_секретную_фразу

# Google OAuth — публичный Client ID (тип Web application из Google Cloud Console).
# Используется бэкендом (проверка id_token) и фронтом (build-arg). Это не секрет.
# Если пусто — кнопка «Войти через Google» просто не показывается.
GOOGLE_CLIENT_ID=

# Web Push (VAPID) — напоминания у задач. Сгенерировать пару:
#   npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY также передаётся во фронт как build-arg NEXT_PUBLIC_VAPID_PUBLIC_KEY
# (см. docker-compose.prod.yml) — поэтому пересобери web после смены ключа.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tryundertea@gmail.com

# Секрет для подписанных токенов действий уведомления (snooze/done из Service Worker).
# openssl rand -hex 32
REMINDER_TOKEN_SECRET=замени_на_случайную_строку_32_символа

# API_PUBLIC_URL для ссылок snooze/done уже задан в docker-compose.prod.yml
# (https://manager.warmingtea.su/api) — отдельно в .env.prod не нужен.
